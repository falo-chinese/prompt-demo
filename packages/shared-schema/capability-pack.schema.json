{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://falo.local/schemas/capability-pack.schema.json",
  "title": "FALO Capability Pack",
  "type": "object",
  "required": [
    "type",
    "packId",
    "packName",
    "version",
    "provider",
    "licenseType",
    "enabledCapabilities"
  ],
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "faloCapabilityPack"
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "packName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "licenseType": {
      "type": "string",
      "enum": [
        "free",
        "teaching",
        "internal",
        "trial",
        "paid",
        "unknown"
      ]
    },
    "enabledCapabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "prompt.basic",
          "json.connect",
          "ocr.postprocess",
          "voice.dictation",
          "workflow.rfp",
          "teaching.demo",
          "gas.connect",
          "audit.review"
        ]
      }
    },
    "prompts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/promptCategory"
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflow"
      }
    },
    "variables": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "uiPanels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/uiPanel"
      }
    },
    "inputMaterials": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "sampleData": {
      "type": "object",
      "additionalProperties": true
    },
    "expiresAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "signature": {
      "type": ["string", "null"]
    },
    "gasEndpoint": {
      "type": ["string", "null"],
      "format": "uri"
    }
  },
  "$defs": {
    "promptCategory": {
      "type": "object",
      "required": ["id", "title", "items"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/promptCard"
          }
        }
      }
    },
    "promptCard": {
      "type": "object",
      "required": ["id", "title", "promptText"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "promptText": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": ["stable", "draft", "review", "deprecated"]
        },
        "variables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expectedOutput": {
          "type": "string"
        },
        "humanReviewPoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["id", "title", "steps"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["stepId", "title"],
            "additionalProperties": true,
            "properties": {
              "stepId": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "promptIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "uiPanel": {
      "type": "object",
      "required": ["panelId", "title", "capability"],
      "additionalProperties": false,
      "properties": {
        "panelId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "capability": {
          "type": "string"
        },
        "state": {
          "type": "string",
          "enum": ["enabled", "locked", "hidden", "preview"]
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
